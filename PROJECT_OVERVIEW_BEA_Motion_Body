# Get 3D coordinates
hands_3d = stereo.get_hands_3d()

for hand in hands_3d:
    for landmark in hand.landmarks_3d:
        print(f"X: {landmark.x:.3f}m")  # Absolute distance
        print(f"Y: {landmark.y:.3f}m")
        print(f"Z: {landmark.z:.3f}m")
```

